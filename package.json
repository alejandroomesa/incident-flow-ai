{
  "name": "incident-flow-ai",
  "version": "1.0.0",
  "description": "Data protection incident classification and management agent with human-in-the-loop approval",
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i ./styles/input.css -o ./public/styles.css --minify",
    "dev": "npm run build:css && tsx watch src/server.ts",
    "build": "npm run build:css && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "mysql2": "^3.11.3",
    "openai": "^6.47.0",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
