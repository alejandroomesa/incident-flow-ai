PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3307
DB_USER=incidentflow
DB_PASSWORD=incidentflow
DB_NAME=incident_flow

OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Modelo gratuito por defecto (sin coste). Si te da 429 (saturado), prueba otro modelo
# ":free" de https://openrouter.ai/models?max_price=0. Para usar Claude real de pago,
# cambia a p.ej. anthropic/claude-sonnet-5
CLAUDE_MODEL=nvidia/nemotron-nano-9b-v2:free

WEBHOOK_SECRET=change-me-demo-secret
WEBHOOK_MAX_AGE_SECONDS=300
